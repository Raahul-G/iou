{
  "expo": {
    "name": "IOU",
    "slug": "iou",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "iou",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.fridayvision.iou",
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.fridayvision.iou",
      "versionCode": 9,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#fff1e4"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon-32x32.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "IOU needs access to your photos to set a profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fff1e4",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "iou",
          "organization": "fridayvision"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon.png",
          "color": "#D4A5A5",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f36b7165-47c1-47df-821f-af5fb50d19cf"
      }
    },
    "owner": "iouapp"
  }
}
